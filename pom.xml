<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>top.jiangqiang.tools</groupId>
  <artifactId>sql-tool</artifactId>
  <version>1.0.0</version>
  <packaging>jar</packaging>

  <name>sql-tool</name>
  <description>Minimal JDBC SQL CLI</description>

  <properties>
      <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
      <maven.compiler.release>17</maven.compiler.release>
      <main.class>top.jiangqiang.tools.SqlTool</main.class>
      <jpackage.name>sql-tool</jpackage.name>
      <jpackage.app.version>1.0.0</jpackage.app.version>
    </properties>

  <dependencies>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-compiler-plugin</artifactId>
        <version>3.13.0</version>
        <configuration>
          <release>${maven.compiler.release}</release>
        </configuration>
      </plugin>
       <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-jar-plugin</artifactId>
        <version>3.4.2</version>
        <configuration>
          <archive>
              <manifest>
                <mainClass>${main.class}</mainClass>
              </manifest>
          </archive>
        </configuration>
      </plugin>
            <plugin>
            <groupId>org.apache.maven.plugins</groupId>
            <artifactId>maven-antrun-plugin</artifactId>
            <version>1.8</version>
            <executions>
              <execution>
                <id>prepare-jpackage-input</id>
                <phase>prepare-package</phase>
                <goals>
                  <goal>run</goal>
                </goals>
                <configuration>
                  <target>
                    <mkdir dir="${project.build.directory}/jpackage-input"/>
                  </target>
                </configuration>
              </execution>
              <execution>
                <id>copy-jar</id>
                <phase>package</phase>
                <goals>
                  <goal>run</goal>
                </goals>
                <configuration>
                  <target>
                    <copy file="${project.build.directory}/${project.build.finalName}.jar" tofile="${project.build.directory}/jpackage-input/${project.build.finalName}.jar"/>
                  </target>
                </configuration>
              </execution>
              <execution>
                <id>create-custom-runtime</id>
                <phase>package</phase>
                <goals>
                  <goal>run</goal>
                </goals>
                <configuration>
                  <target>
                    <delete dir="${project.build.directory}/custom-runtime" quiet="true"/>
                    <exec executable="jlink" dir="${project.basedir}" failonerror="true">
                      <arg line="--add-modules java.base,java.sql,java.naming,java.management,java.sql.rowset,java.security.jgss,java.security.sasl,jdk.crypto.ec,jdk.crypto.cryptoki,jdk.crypto.mscapi,jdk.charsets,jdk.unsupported"/>
                      <arg line="--strip-debug"/>
                      <arg line="--compress=2"/>
                      <arg line="--no-header-files"/>
                      <arg line="--no-man-pages"/>
                      <arg line="--output ${project.build.directory}/custom-runtime"/>
                    </exec>
                  </target>
                </configuration>
              </execution>
            </executions>
           </plugin>
            <plugin>
            <groupId>org.panteleyev</groupId>
            <artifactId>jpackage-maven-plugin</artifactId>
            <version>1.7.4</version>
            <configuration>
              <name>${jpackage.name}</name>
              <appVersion>${jpackage.app.version}</appVersion>
              <type>APP_IMAGE</type>
              <input>${project.build.directory}/jpackage-input</input>
              <mainClass>${main.class}</mainClass>
              <mainJar>${project.build.finalName}.jar</mainJar>
              <runtimeImage>${project.build.directory}/custom-runtime</runtimeImage>
              <winConsole>true</winConsole>
              <destination>${project.build.directory}/jpackage-output</destination>
            </configuration>
          </plugin>
     </plugins>
   </build>
</project>
