<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>top.jiangqiang</groupId>
    <artifactId>sql-tool</artifactId>
    <version>1.0.0</version>

    <name>SQL Operation Tool</name>
    <description>Command-line tool for database operations with dynamic driver loading</description>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <jpackage.mainClass>top.jiangqiang.tools.SqlTool</jpackage.mainClass>
        <graalvm.version>0.9.27</graalvm.version>
    </properties>

    <dependencies>
        <!-- MySQL JDBC Driver -->
        <dependency>
            <groupId>com.mysql</groupId>
            <artifactId>mysql-connector-j</artifactId>
            <version>8.0.33</version>
        </dependency>

        <!-- PostgreSQL JDBC Driver -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>42.6.0</version>
        </dependency>

        <!-- SQLite JDBC Driver -->
        <dependency>
            <groupId>org.xerial</groupId>
            <artifactId>sqlite-jdbc</artifactId>
            <version>3.42.0.0</version>
        </dependency>

        <!-- Microsoft SQL Server JDBC Driver -->
        <dependency>
            <groupId>com.microsoft.sqlserver</groupId>
            <artifactId>mssql-jdbc</artifactId>
            <version>9.4.1.jre8</version>
        </dependency>

        <!-- Oracle JDBC Driver -->
        <dependency>
            <groupId>com.oracle.database.jdbc</groupId>
            <artifactId>ojdbc8</artifactId>
            <version>21.13.0.0</version>
            <exclusions>
                <exclusion>
                    <groupId>com.oracle.database.jdbc</groupId>
                    <artifactId>oraclepki</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
    </dependencies>

    <profiles>
        <profile>
            <id>native</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.graalvm.buildtools</groupId>
                        <artifactId>native-maven-plugin</artifactId>
                        <version>${graalvm.version}</version>
                        <extensions>true</extensions>
                        <configuration>
                            <mainClass>top.jiangqiang.tools.SqlTool</mainClass>
                            <imageName>sqltool</imageName>
                            <fallback>false</fallback>
                            <verbose>true</verbose>
                             <buildArgs>
                                 <buildArg>--features=oracle.nativeimage.NativeImageFeature,oracle.nativeimage.CharacterSetFeature,org.sqlite.nativeimage.SqliteJdbcFeature</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.sql.ConverterArchive</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.sql.converter.CharacterConverterJDBC</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.sql.CharacterSet1Byte</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.sql.converter.CharacterConverter1Byte</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.sql.CharacterSetWithConverter</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.sql.CharacterSetAL32UTF8</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.sql.CharacterSetUTF</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.sql.CharacterSetAL16UTF16</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.sql.CharacterSetUTFE</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.sql.CharacterSetAL16UTF16LE</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.net.jdbc.nl.mesg.NLSR_en</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.jdbc.driver.DynamicByteArray</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.jdbc.logging.runtime.TraceControllerImpl</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.jdbc.driver.ClioSupport</buildArg>
                                 <buildArg>--initialize-at-build-time=oracle.jdbc.driver.ClioSupport$1</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.OracleDriver</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.driver.OracleDriver</buildArg>
                                 <buildArg>--initialize-at-run-time=java.sql.DriverManager</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.driver.LogicalConnection</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.pool.OraclePooledConnection</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.pool.OracleDataSource</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.datasource.impl.OracleDataSource</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.pool.OracleOCIConnectionPool</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.driver.OracleTimeoutThreadPerVM</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.net.nt.TimeoutInterruptHandler</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.driver.HAManager</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.net.nt.Clock</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.net.nt.TcpMultiplexer</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.net.nt.TcpMultiplexer$LazyHolder</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.driver.BlockSource$ThreadedCachingBlockSource</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.driver.BlockSource$ThreadedCachingBlockSource$BlockReleaser</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.xa.client.OracleXADataSource</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.replay.OracleXADataSourceImpl</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.datasource.OracleXAConnection</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.xa.client.OracleXAConnection</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.xa.client.OracleXAHeteroConnection</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.jdbc.driver.T4CXAConnection</buildArg>
                                 <buildArg>--initialize-at-run-time=oracle.security.o5logon.O5Logon</buildArg>
                                 <buildArg>-H:EnableURLProtocols=http</buildArg>
                                 <buildArg>-H:EnableURLProtocols=https</buildArg>
                             </buildArgs>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <release>17</release>
                </configuration>
            </plugin>
              <plugin>
                  <groupId>org.apache.maven.plugins</groupId>
                  <artifactId>maven-jar-plugin</artifactId>
                  <version>3.4.1</version>
                  <configuration>
                      <archive>
                          <manifest>
                              <mainClass>top.jiangqiang.tools.SqlTool</mainClass>
                          </manifest>
                      </archive>
                      <excludes>
                          <exclude>META-INF/native-image/native-image.properties</exclude>
                          <exclude>META-INF/native-image/*.json</exclude>
                      </excludes>
                  </configuration>
              </plugin>
              <plugin>
                  <groupId>org.apache.maven.plugins</groupId>
                  <artifactId>maven-surefire-plugin</artifactId>
                  <version>3.5.2</version>
                  <configuration>
                      <systemPropertyVariables>
                      </systemPropertyVariables>
                  </configuration>
              </plugin>
         </plugins>
     </build>
 </project>
